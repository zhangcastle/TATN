  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5：数据处理\n",
    "根据上面的文件列表，自动处理原始数据 → `normalized_data/Pan/{temp}/`\n",
    "\n",
    "**如果上面某个温度的路径不存在，请修改 `temp_folders` 字典后重新运行。**"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import scipy.io as sio\n",
    "import numpy as np\n",
    "\n",
    "# 9 个 drive cycle 的关键词，用于从文件名自动匹配\n",
    "DRIVE_CYCLE_KEYWORDS = {\n",
    "    'Cycle_1': ['Cycle_1', 'Cycle1', 'cycle1', 'cycle_1'],\n",
    "    'Cycle_2': ['Cycle_2', 'Cycle2', 'cycle2', 'cycle_2'],\n",
    "    'Cycle_3': ['Cycle_3', 'Cycle3', 'cycle3', 'cycle_3'],\n",
    "    'Cycle_4': ['Cycle_4', 'Cycle4', 'cycle4', 'cycle_4'],\n",
    "    'NN':      ['NN', 'nn'],\n",
    "    'US06':    ['US06', 'us06'],\n",
    "    'HWFET':   ['HWFET', 'hwfet'],\n",
    "    'LA92':    ['LA92', 'la92'],\n",
    "    'UDDS':    ['UDDS', 'udds'],\n",
    "}\n",
    "\n",
    "def match_cycle_name(filename):\n",
    "    \"\"\"从文件名中识别是哪个 drive cycle\"\"\"\n",
    "    for cycle, keywords in DRIVE_CYCLE_KEYWORDS.items():\n",
    "        for kw in keywords:\n",
    "            if kw in filename:\n",
    "                return cycle\n",
    "    return None\n",
    "\n",
    "def read_panasonic_mat(filepath):\n",
    "    \"\"\"读取原始 Panasonic .mat 文件（meas struct 格式）\"\"\"\n",
    "    data = sio.loadmat(filepath)\n",
    "    if 'meas' in data:\n",
    "        # 原始格式：nested struct\n",
    "        meas = data['meas']\n",
    "        time    = meas['Time'][0][0].flatten()\n",
    "        current = meas['Current'][0][0].flatten()\n",
    "        voltage = meas['Voltage'][0][0].flatten()\n",
    "        temp    = meas['Battery_Temp_degC'][0][0].flatten()\n",
    "        ah      = meas['Ah'][0][0].flatten()\n",
    "    else:\n",
    "        # 已经过 read_and_save 处理的格式\n",
    "        time    = data['time'].flatten()\n",
    "        current = data['current'].flatten()\n",
    "        voltage = data['voltage'].flatten()\n",
    "        temp    = data['temp'].flatten()\n",
    "        ah      = data['ah'].flatten()\n",
    "    return time, current, voltage, temp, ah\n",
    "\n",
    "def find_start_idx(time):\n",
    "    \"\"\"找到时间连续的起始点（去掉初始充电段）\"\"\"\n",
    "    for i in range(len(time) - 1):\n",
    "        if (time[i+1] - time[i]) < 2:\n",
    "            return i\n",
    "    return 0\n",
    "\n",
    "def process_one_temperature(raw_drive_cycles_path, temp_label, output_base, interval=10, train_ratio=0.3):\n",
    "    \"\"\"\n",
    "    完整处理一个温度的数据：\n",
    "    1. 读取原始 .mat 文件\n",
    "    2. 降采样 (interval=10)\n",
    "    3. 计算全局 min/max（用于归一化）\n",
    "    4. 归一化到 [0,1]\n",
    "    5. 切分 train/test (前 train_ratio 做训练)\n",
    "    6. 保存到 output_base/{temp_label}/\n",
    "    \"\"\"\n",
    "    output_path = os.path.join(output_base, temp_label)\n",
    "    os.makedirs(output_path, exist_ok=True)\n",
    "\n",
    "    mat_files = [f for f in os.listdir(raw_drive_cycles_path) if f.endswith('.mat')]\n",
    "    if not mat_files:\n",
    "        print(f'[{temp_label}] 没有找到 .mat 文件，跳过')\n",
    "        return\n",
    "\n",
    "    # ---- Pass 1: 读取所有文件，找全局 min/max ----\n",
    "    all_data = {}\n",
    "    for fname in mat_files:\n",
    "        cycle_name = match_cycle_name(fname)\n",
    "        if cycle_name is None:\n",
    "            print(f'  [警告] 无法识别 drive cycle: {fname}，跳过')\n",
    "            continue\n",
    "        fpath = os.path.join(raw_drive_cycles_path, fname)\n",
    "        time, current, voltage, temp_data, ah = read_panasonic_mat(fpath)\n",
    "\n",
    "        # 降采样\n",
    "        time     = time[::interval]\n",
    "        current  = current[::interval]\n",
    "        voltage  = voltage[::interval]\n",
    "        temp_data = temp_data[::interval]\n",
    "        ah       = ah[::interval]\n",
    "\n",
    "        # 找连续段起始点\n",
    "        idx = find_start_idx(time)\n",
    "        current  = current[idx:]\n",
    "        voltage  = voltage[idx:]\n",
    "        temp_data = temp_data[idx:]\n",
    "        ah       = ah[idx:]\n",
    "\n",
    "        all_data[cycle_name] = (current, voltage, temp_data, ah)\n",
    "        print(f'  [{temp_label}] 读取: {fname} → {cycle_name}  len={len(ah)}')\n",
    "\n",
    "    if not all_data:\n",
    "        print(f'[{temp_label}] 没有成功读取任何文件')\n",
    "        return\n",
    "\n",
    "    # 计算全局 min/max（论文：归一化基于该温度所有 drive cycle 的全局范围）\n",
    "    all_current = np.concatenate([v[0] for v in all_data.values()])\n",
    "    all_voltage = np.concatenate([v[1] for v in all_data.values()])\n",
    "    all_temp    = np.concatenate([v[2] for v in all_data.values()])\n",
    "    all_ah      = np.concatenate([v[3] for v in all_data.values()])\n",
    "\n",
    "    ranges = {\n",
    "        'current': (all_current.min(), all_current.max()),\n",
    "        'voltage': (all_voltage.min(), all_voltage.max()),\n",
    "        'temp':    (all_temp.min(),    all_temp.max()),\n",
    "        'ah':      (all_ah.min(),      all_ah.max()),\n",
    "    }\n",
    "    print(f'\\n  [{temp_label}] 归一化范围：')\n",
    "    for k, (mn, mx) in ranges.items():\n",
    "        print(f'    {k}: [{mn:.4f}, {mx:.4f}]')\n",
    "\n",
    "    def normalize(x, mn, mx):\n",
    "        return (x - mn) / (mx - mn)\n",
    "\n",
    "    # ---- Pass 2: 归一化 + 切分 + 保存 ----\n",
    "    for cycle_name, (current, voltage, temp_data, ah) in all_data.items():\n",
    "        current_n  = normalize(current,   *ranges['current'])\n",
    "        voltage_n  = normalize(voltage,   *ranges['voltage'])\n",
    "        temp_n     = normalize(temp_data, *ranges['temp'])\n",
    "        ah_n       = normalize(ah,        *ranges['ah'])\n",
    "\n",
    "        n = len(ah_n)\n",
    "        split = int(n * train_ratio)\n",
    "\n",
    "        for suffix, sl in [('train', slice(None, split)), ('test', slice(split, None))]:\n",
    "            out_file = os.path.join(output_path, f'{temp_label}{cycle_name}_{suffix}.mat')\n",
    "            sio.savemat(out_file, {\n",
    "                'current': current_n[sl].reshape(-1, 1),\n",
    "                'voltage': voltage_n[sl].reshape(-1, 1),\n",
    "                'temp':    temp_n[sl].reshape(-1, 1),\n",
    "                'ah':      ah_n[sl].reshape(-1, 1),\n",
    "            })\n",
    "\n",
    "        print(f'  [{temp_label}] 保存: {cycle_name}  train={split}  test={n-split}')\n",
    "\n",
    "    print(f'\\n[{temp_label}] 处理完成 → {output_path}\\n')\n",
    "\n",
    "print('数据处理函数定义完成')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# 处理所有温度\n",
    "OUTPUT_BASE = os.path.join(WORK_DIR, 'normalized_data', 'Pan')\n",
    "\n",
    "for temp_label, raw_path in temp_folders.items():\n",
    "    print(f'========== 处理 {temp_label}°C ==========')\n",
    "    if os.path.exists(raw_path):\n",
    "        process_one_temperature(raw_path, temp_label, OUTPUT_BASE)\n",
    "    else:\n",
    "        print(f'路径不存在，跳过: {raw_path}')\n",
    "\n",
    "print('\\n全部处理完成！输出目录：', OUTPUT_BASE)\n",
    "for temp in ['25', '10', '0', 'n10', 'n20']:\n",
    "    p = os.path.join(OUTPUT_BASE, temp)\n",
    "    if os.path.exists(p):\n",
    "        files = os.listdir(p)\n",
    "        print(f'  {temp}/  ({len(files)} 个文件)')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 6：预训练（5 个温度依次跑）\n",
    "每个温度跑 2000 epoch，结果保存在 `run/pretrain_{temp}/`"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import sys\n",
    "sys.path.insert(0, WORK_DIR)\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from models import conv, lstm, fc, regression\n",
    "from pretrain import pretrain\n",
    "import mydata\n",
    "\n",
    "DEVICE = 'cuda:0' if torch.cuda.is_available() else 'cpu'\n",
    "EPOCHS = 2000\n",
    "BATCH_SIZE = 64\n",
    "EVAL_INTERVAL = 200\n",
    "LR = 0.001\n",
    "\n",
    "# 更新 mydata 路径为处理后数据目录\n",
    "mydata.Pan_data_path = OUTPUT_BASE + '/'\n",
    "\n",
    "TEMPS = ['25', '10', '0', 'n10', 'n20']\n",
    "\n",
    "print(f'Device: {DEVICE}')\n",
    "print(f'Epochs: {EPOCHS}, Batch: {BATCH_SIZE}')\n",
    "print(f'Temps to pretrain: {TEMPS}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import time\n",
    "\n",
    "results_summary = {}\n",
    "\n",
    "for temp in TEMPS:\n",
    "    print(f'\\n{\"=\"*60}')\n",
    "    print(f'预训练温度: {temp}°C')\n",
    "    print(f'{\"=\"*60}')\n",
    "\n",
    "    # 检查数据是否存在\n",
    "    temp_data_path = os.path.join(OUTPUT_BASE, temp)\n",
    "    if not os.path.exists(temp_data_path) or len(os.listdir(temp_data_path)) == 0:\n",
    "        print(f'[跳过] {temp} 的数据不存在')\n",
    "        continue\n",
    "\n",
    "    # 初始化模型（每个温度重新初始化）\n",
    "    models = {\n",
    "        'conv':       conv(),\n",
    "        'lstm':       lstm(),\n",
    "        'fc':         fc(),\n",
    "        'regression': regression(),\n",
    "        'conv_s':     conv(),\n",
    "        'lstm_s':     lstm(),\n",
    "        'fc_s':       fc(),\n",
    "        'regression_s': regression(),\n",
    "        'discriminator': __import__('models').Discriminator(),\n",
    "    }\n",
    "    optimizers = {\n",
    "        'conv':       optim.Adam(models['conv'].parameters(),       lr=LR),\n",
    "        'lstm':       optim.Adam(models['lstm'].parameters(),       lr=LR),\n",
    "        'fc':         optim.Adam(models['fc'].parameters(),         lr=LR),\n",
    "        'regression': optim.Adam(models['regression'].parameters(), lr=LR),\n",
    "        'discriminator': optim.Adam(models['discriminator'].parameters(), lr=LR),\n",
    "    }\n",
    "    criterion = nn.MSELoss(reduction='sum')\n",
    "\n",
    "    t0 = time.time()\n",
    "    pretrain(\n",
    "        rundir=f'pretrain_{temp}',\n",
    "        source_temp=temp,\n",
    "        target_temp=temp,\n",
    "        source_data_path=OUTPUT_BASE + '/',\n",
    "        source_train_set=mydata.Pan_train_set,\n",
    "        source_test_set=mydata.Pan_test_set,\n",
    "        models=models,\n",
    "        criterion=criterion,\n",
    "        optimizers=optimizers,\n",
    "        batch_size=BATCH_SIZE,\n",
    "        epochs=EPOCHS,\n",
    "        eval_interval=EVAL_INTERVAL,\n",
    "        seed=100,\n",
    "        device_type=DEVICE,\n",
    "        ifsave=True,\n",
    "        load_model=False,\n",
    "    )\n",
    "    elapsed = (time.time() - t0) / 60\n",
    "    print(f'[{temp}°C] 完成，耗时 {elapsed:.1f} min')\n",
    "    results_summary[temp] = elapsed\n",
    "\n",
    "print('\\n\\n========== 预训练全部完成 ==========')\n",
    "for temp, mins in results_summary.items():\n",
    "    print(f'  {temp}°C : {mins:.1f} min')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
